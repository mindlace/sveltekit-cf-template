import { drizzle } from 'drizzle-orm/d1';
import type { DrizzleD1Database } from 'drizzle-orm/d1';
import * as schema from './schema/schema';
import { building } from '$app/environment';

export type Database = DrizzleD1Database<typeof schema>;

let _db: Database | undefined;
let _d1Binding: unknown | undefined;

function initDb(platform: App.Platform): Database {
  const d1 = platform.env.DB;

  if (_db && d1 === _d1Binding) {
    return _db;
  }

  if (building) {
    return new Proxy({} as Database, {
      get() {
        throw new Error('Database cannot be accessed during build');
      }
    }) as Database;
  }

  if (!d1) {
    throw new Error(
      'D1 database binding "DB" not found in platform.env. ' +
        'Make sure you are running with wrangler dev (for local) or deployed to Cloudflare Workers.'
    );
  }

  _d1Binding = d1;
  _db = drizzle(d1, { schema });
  return _db;
}

export function getDb(platform: App.Platform): Database {
  return initDb(platform);
}
