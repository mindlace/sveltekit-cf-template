{
  "name": "{{ project_name }}",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "prepare": "husky && (svelte-kit sync || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test": "vitest --run",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate && npx tsx src/scripts/prepare-migrations.ts",
    "db:migrate": "npx tsx src/scripts/migrate.ts",
    "db:migrate:prod": "npx tsx src/scripts/migrate.ts --remote",
    "db:studio": "drizzle-kit studio",
    "types": "wrangler types",
    "deploy:prod": "npm run build && wrangler deploy"
  },
  "lint-staged": {
    "*.{ts,svelte,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,json,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.17",
    "@vitest/browser-playwright": "^4.0.16",
    "drizzle-kit": "^1.0.0-beta.6-4414a19",
    "drizzle-orm": "^1.0.0-beta.6-4414a19",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mdsvex": "^0.12.6",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.2.6",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.15",
    "vitest-browser-svelte": "^2.0.1",
    "wrangler": "^4.54.0"
  },
  "dependencies": {}
}
